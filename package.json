{
  "name": "e-wallet",
  "version": "1.0.0",
  "description": "Multi-currency E-Wallet backend with ledger-based audit trail",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit",
    "test:verbose": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --verbose",
    "test:coverage": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --coverage",
    "migrate": "knex migrate:latest",
    "migrate:down": "knex migrate:rollback",
    "migrate:make": "knex migrate:make"
  },
  "keywords": [
    "wallet",
    "fintech",
    "ledger",
    "multi-currency"
  ],
  "author": "",
  "license": "ISC",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "transform": {}
  },
  "dependencies": {
    "cors": "^2.8.5",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "knex": "^3.2.9",
    "morgan": "^1.10.0",
    "pg": "^8.14.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.0"
  }
}
